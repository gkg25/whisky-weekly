# =========================================================
# Whisky Weekly 環境変数サンプル
# このファイルをコピーして「.env」にリネームし、各値を埋めてください。
# .env は Git にコミットされません（.gitignore で除外）。
# =========================================================

# --- Gemini API キー（無料枠） ---
# 取得手順:
#   1. https://aistudio.google.com/ に Google アカウントでログイン
#   2. 画面左上「Get API key」→「Create API key」
#   3. 表示された文字列をコピーして以下に貼り付け
GEMINI_API_KEY=ここにGeminiのAPIキー

# --- Gmail 送信元アドレス ---
GMAIL_ADDRESS=tomoko@gakkogawa.com

# --- Gmail アプリパスワード ---
# 取得手順:
#   1. https://myaccount.google.com/security に行く
#   2. 「2段階認証プロセス」を有効化
#   3. 「アプリパスワード」→「アプリ名」を Whisky Weekly などに設定して作成
#   4. 表示された16桁の文字列（スペース無しで貼り付け）
GMAIL_APP_PASSWORD=ここに16桁のアプリパスワード

# --- 受信先メールアドレス（複数可・BCC一括送信） ---
# 単独：
#   RECIPIENT_EMAIL=tomoko@gakkogawa.com
# 複数（カンマ区切り、空白は自動trim）：
#   RECIPIENT_EMAIL=tomoko@gakkogawa.com, satou@gakkogawa.com, suzuki@gakkogawa.com
# 受信者同士には互いのアドレスは見えません（BCC方式）
RECIPIENT_EMAIL=tomoko@gakkogawa.com
